# ---------------------------------------------------------------------------
# StudyShare environment. Copy to .env and adjust. Never commit real secrets.
# The API validates this at boot (apps/api/src/config/env.ts) and refuses to
# start on missing/invalid values.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Public URLs
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173
# Comma-separated allowlist of browser origins permitted by CORS
CORS_ORIGIN=http://localhost:5173

# Database (Postgres)
# Dev compose publishes Postgres on host port 55432 (avoids clashing with a
# local Postgres on 5432). Inside the compose network the API uses port 5432.
DATABASE_URL=postgresql://studyshare:studyshare@localhost:55432/studyshare

# JWT / crypto secrets — MUST be >= 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32chars-minimum
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32chars-minimum
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=studyshare
JWT_AUDIENCE=studyshare-web
COOKIE_SECRET=dev-cookie-secret-change-me-please-32chars-minimum
CSRF_SECRET=dev-csrf-secret-change-me-please-32chars-minimum

# Cookies
# COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth (optional — leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_PATH=/api/auth/google/callback

# SMTP (Mailhog by default in dev — UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=StudyShare <no-reply@studyshare.local>

# Object storage (MinIO — console at http://localhost:9001)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=studyshare
S3_FORCE_PATH_STYLE=true
DOWNLOAD_URL_TTL_SECONDS=300

# Uploads
MAX_UPLOAD_BYTES=26214400        # 25 MB
USER_STORAGE_QUOTA_BYTES=524288000 # 500 MB

# Rate limits
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW=1 minute
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=1 minute
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW=1 minute

# Error reporting (optional; Sentry-ready)
SENTRY_DSN=
